{
  "name": "web-analyzer-online",
  "version": "1.0.0",
  "description": "日本語サイト専用Web分析システム（オンライン版）",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch app.js",
    "analyze": "node src/analyze-all.js",
    "build": "mkdir -p dist && cp -r public/* dist/ && cp app.js dist/",
    "postinstall": "node -e \"process.exit(process.env.PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD === '1' ? 0 : 1)\" || npx playwright install chromium"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "playwright": "1.58.2",
    "openai": "^4.20.0",
    "dotenv": "^16.3.0",
    "axe-core": "^4.8.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
